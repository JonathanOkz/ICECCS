# Copy this file to .env, replace the example values as needed, then run:
#   source .env
#
# Do not store private keys here. Supply the broadcasting account through Forge
# with --account, --private-key, or --ledger.

# Local Anvil by default; replace with the target network RPC endpoint.
export RPC_URL=http://127.0.0.1:8545

# Optional token metadata.
export CAF_NAME="Challenge-Aware Token"
export CAF_SYMBOL=CAF

# Initial distribution and protocol windows.
export CAF_INITIAL_HOLDER=0x1111111111111111111111111111111111111111
export CAF_INITIAL_SUPPLY=1000000000000000000000000
export CAF_CHALLENGE_WINDOW=604800
export CAF_REVIEW_WINDOW=172800

# Immutable protocol membership. All addresses must be non-zero and distinct.
export CAF_CHALLENGERS=0x2222222222222222222222222222222222222222,0x3333333333333333333333333333333333333333
export CAF_VALIDATORS=0x4444444444444444444444444444444444444444,0x5555555555555555555555555555555555555555,0x6666666666666666666666666666666666666666,0x7777777777777777777777777777777777777777,0x8888888888888888888888888888888888888888,0x9999999999999999999999999999999999999999,0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
export CAF_QUORUM=5
